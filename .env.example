# ── Redis ──────────────────────────────────────────────────────────────────────
# Development: use a local Redis instance (Docker or Homebrew)
REDIS_LOCAL=true
REDIS_URL=redis://localhost:6379

# Production (Upstash): set these and remove REDIS_LOCAL / REDIS_URL
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── API ────────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Cronitor (optional) ────────────────────────────────────────────────────────
CRONITOR_API_KEY=your-cronitor-api-key
