    "@upstash/redis": "^1.34.3",
    "graphql": "^16.10.0",
    "graphql-yoga": "^5.10.7",
    "hono": "^4.7.0",
    "ioredis": "^5.10.1",
    "nanoid": "^5.0.9",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "bun-types": "^1.3.13",
